# Uygulama
APP_URL=https://platform.com
NODE_ENV=production

# Veritabanı
DB_PASSWORD=changeme_strong_password
DATABASE_URL=postgresql://postgres:${DB_PASSWORD}@db:5432/randevu_db

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_ACCESS_SECRET=change_me_access_secret_min_32chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# SMS — İletimerkezi
ILETIMERKEZI_API_KEY=
ILETIMERKEZI_SENDER=
ILETIMERKEZI_HASH=

# WhatsApp Business API
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Dosya Depolama
UPLOAD_DRIVER=local
UPLOAD_LOCAL_PATH=./uploads
UPLOAD_BASE_URL=https://platform.com/uploads
